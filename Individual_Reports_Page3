<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Elizabethtown College Athletics - Individual Reports</title>
    <link rel="stylesheet" href="styles.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body>

    <!-- HEADER -->
    <div class="header">
        <h1>Elizabethtown College Athletics</h1>
        <div class="header-right">
            <button class="menu-btn">···</button>
            <button class="share-btn">Share</button>
            <div class="profile-pic"></div>
            <span class="chevron">▾</span>
        </div>
    </div>

    <!-- NAV -->
    <div class="nav">
        <div class="nav-item">Home</div>
        <div class="nav-item">Session Recording</div>
        <div class="nav-item active">Individual Reports</div>
        <div class="nav-search">🔍 Search Athletes...</div>
    </div>

    <!-- MAIN CONTENT -->
    <div class="container">

        <!-- TOP METRICS ROW -->
        <div class="ir-top-row">

            <!-- Vertical Jump PR -->
            <div class="ir-pr-card">
                <div class="ir-pr-label">Vertical Jump PR (in)</div>
                <div class="ir-pr-value">19.9</div>
                <div class="ir-pr-sub">#2 All Time</div>
            </div>

            <!-- 40-Yard Dash PR -->
            <div class="ir-pr-card">
                <div class="ir-pr-label">40-Yard Dash PR (s)</div>
                <div class="ir-pr-value">4.77</div>
                <div class="ir-pr-sub">#15 All Time</div>
            </div>

            <!-- Test Selector -->
            <div class="ir-test-selector">
                <div class="ir-test-title">Vertical Jump</div>
                <div class="ir-test-sub">Select Test</div>
            </div>

        </div>

        <!-- MIDDLE ROW: Athlete Bio + Chart -->
        <div class="ir-middle-row">

            <!-- Left: Athlete Profile -->
            <div class="ir-profile-card">
                <div class="ir-profile-header">
                    <div class="ir-athlete-name">Evan Swanson</div>
                    <button class="ir-bio-btn">Biography</button>
                </div>
                <div class="ir-profile-body">
                    <div class="ir-athlete-photo">
                        <!-- Simulated athlete photo placeholder -->
                        <div class="ir-photo-placeholder">
                            <svg viewBox="0 0 100 120" fill="none" xmlns="http://www.w3.org/2000/svg" width="100" height="120">
                                <!-- Jersey body -->
                                <rect x="15" y="50" width="70" height="65" rx="4" fill="#1a3a6b"/>
                                <!-- Number on jersey -->
                                <text x="50" y="95" text-anchor="middle" fill="white" font-size="22" font-weight="bold" font-family="Arial">24</text>
                                <!-- Head -->
                                <circle cx="50" cy="30" r="22" fill="#c8a882"/>
                                <!-- Cap brim -->
                                <rect x="28" y="10" width="44" height="8" rx="2" fill="#1a3a6b"/>
                                <rect x="22" y="15" width="10" height="4" rx="1" fill="#1a3a6b"/>
                                <!-- Face features -->
                                <circle cx="42" cy="32" r="2.5" fill="#7a5c3a"/>
                                <circle cx="58" cy="32" r="2.5" fill="#7a5c3a"/>
                                <path d="M 43 42 Q 50 47 57 42" stroke="#7a5c3a" stroke-width="1.5" fill="none"/>
                                <!-- Arms -->
                                <rect x="0" y="52" width="18" height="35" rx="6" fill="#1a3a6b"/>
                                <rect x="82" y="52" width="18" height="35" rx="6" fill="#1a3a6b"/>
                                <!-- Team text on jersey -->
                                <text x="50" y="68" text-anchor="middle" fill="#a8c4e8" font-size="8" font-family="Arial" font-weight="bold">BLUE JAYS</text>
                            </svg>
                        </div>
                    </div>
                    <div class="ir-athlete-details">
                        <div class="ir-detail-row"><span class="ir-detail-label">Team:</span> <span class="ir-detail-value">Baseball</span></div>
                        <div class="ir-detail-row"><span class="ir-detail-label">Year:</span> <span class="ir-detail-value">Senior</span></div>
                        <div class="ir-detail-row"><span class="ir-detail-label">Height:</span> <span class="ir-detail-value">6-3</span></div>
                        <div class="ir-detail-row"><span class="ir-detail-label">Weight:</span> <span class="ir-detail-value">180</span></div>
                        <div class="ir-detail-row"><span class="ir-detail-label">Major:</span> <span class="ir-detail-value">Engineering</span></div>
                    </div>
                </div>
            </div>

            <!-- Right: Jump Height Chart -->
            <div class="chart-card ir-chart-card">
                <div class="ir-chart-label">Average Jump Height (in)</div>
                <div class="ir-line-chart-container">
                    <canvas id="jumpLineChart"></canvas>
                </div>
            </div>

        </div>

        <!-- BOTTOM ROW: Recent Tests + Video Reps -->
        <div class="ir-bottom-row">

            <!-- Recent Tests Table -->
            <div class="table-card ir-tests-card">
                <div class="chart-title">Recent Tests</div>
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Type</th>
                            <th>Change</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>10/23/25</td>
                            <td>Jump</td>
                            <td><span class="ir-arrow ir-arrow-up">↑</span></td>
                        </tr>
                        <tr>
                            <td>10/21/25</td>
                            <td>Sprint</td>
                            <td><span class="ir-arrow ir-arrow-up">↑</span></td>
                        </tr>
                        <tr>
                            <td>10/18/25</td>
                            <td>Sprint</td>
                            <td><span class="ir-arrow ir-arrow-down">↓</span></td>
                        </tr>
                        <tr>
                            <td>10/15/25</td>
                            <td>Jump</td>
                            <td><span class="ir-arrow ir-arrow-up">↑</span></td>
                        </tr>
                        <tr>
                            <td>10/15/25</td>
                            <td>Sprint</td>
                            <td><span class="ir-arrow ir-arrow-up">↑</span></td>
                        </tr>
                        <tr>
                            <td>10/10/25</td>
                            <td>Jump</td>
                            <td><span class="ir-arrow ir-arrow-down">↓</span></td>
                        </tr>
                        <tr>
                            <td>10/8/25</td>
                            <td>Jump</td>
                            <td><span class="ir-arrow ir-arrow-up">↑</span></td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <!-- Video Reps + Action Buttons -->
            <div class="ir-reps-section">

                <div class="ir-reps-grid">
                    <!-- Best Rep -->
                    <div class="ir-rep-card">
                        <div class="ir-rep-label">Best Rep</div>
                        <div class="ir-rep-video">
                            <div class="ir-rep-overlay">
                                <div class="ir-play-btn">▶</div>
                            </div>
                            <!-- Simulated squat figure -->
                            <svg viewBox="0 0 120 140" fill="none" xmlns="http://www.w3.org/2000/svg" class="ir-rep-svg">
                                <!-- Background wall texture -->
                                <rect width="120" height="140" fill="#d4c9b8"/>
                                <!-- Wall blocks -->
                                <line x1="0" y1="35" x2="120" y2="35" stroke="#c0b5a4" stroke-width="1"/>
                                <line x1="0" y1="70" x2="120" y2="70" stroke="#c0b5a4" stroke-width="1"/>
                                <line x1="0" y1="105" x2="120" y2="105" stroke="#c0b5a4" stroke-width="1"/>
                                <line x1="30" y1="0" x2="30" y2="35" stroke="#c0b5a4" stroke-width="1"/>
                                <line x1="75" y1="0" x2="75" y2="35" stroke="#c0b5a4" stroke-width="1"/>
                                <line x1="15" y1="35" x2="15" y2="70" stroke="#c0b5a4" stroke-width="1"/>
                                <line x1="60" y1="35" x2="60" y2="70" stroke="#c0b5a4" stroke-width="1"/>
                                <line x1="100" y1="35" x2="100" y2="70" stroke="#c0b5a4" stroke-width="1"/>
                                <!-- Floor -->
                                <rect x="0" y="118" width="120" height="22" fill="#b8ad9e"/>
                                <!-- Athlete in squat: black outfit -->
                                <!-- Lower legs -->
                                <rect x="44" y="95" width="10" height="28" rx="3" fill="#1a1a1a" transform="rotate(-15 44 95)"/>
                                <rect x="66" y="95" width="10" height="28" rx="3" fill="#1a1a1a" transform="rotate(15 76 95)"/>
                                <!-- Shoes -->
                                <rect x="36" y="116" width="18" height="7" rx="2" fill="#333"/>
                                <rect x="62" y="116" width="18" height="7" rx="2" fill="#333"/>
                                <!-- Thighs (deep squat) -->
                                <rect x="42" y="72" width="12" height="30" rx="4" fill="#1a1a1a" transform="rotate(30 42 72)"/>
                                <rect x="62" y="72" width="12" height="30" rx="4" fill="#1a1a1a" transform="rotate(-30 74 72)"/>
                                <!-- Torso leaning forward -->
                                <rect x="48" y="45" width="22" height="35" rx="5" fill="#1a1a1a" transform="rotate(10 48 45)"/>
                                <!-- Arms -->
                                <line x1="50" y1="58" x2="34" y2="78" stroke="#1a1a1a" stroke-width="7" stroke-linecap="round"/>
                                <line x1="68" y1="58" x2="82" y2="75" stroke="#1a1a1a" stroke-width="7" stroke-linecap="round"/>
                                <!-- Head -->
                                <circle cx="58" cy="36" r="14" fill="#c8a882"/>
                                <!-- Hair -->
                                <path d="M 44 28 Q 58 18 72 28 Q 70 22 58 20 Q 46 22 44 28Z" fill="#2a1a0a"/>
                            </svg>
                        </div>
                    </div>

                    <!-- Worst Rep -->
                    <div class="ir-rep-card">
                        <div class="ir-rep-label">Worst Rep</div>
                        <div class="ir-rep-video">
                            <div class="ir-rep-overlay">
                                <div class="ir-play-btn">▶</div>
                            </div>
                            <!-- Simulated squat figure (slightly different pose) -->
                            <svg viewBox="0 0 120 140" fill="none" xmlns="http://www.w3.org/2000/svg" class="ir-rep-svg">
                                <rect width="120" height="140" fill="#d4c9b8"/>
                                <line x1="0" y1="35" x2="120" y2="35" stroke="#c0b5a4" stroke-width="1"/>
                                <line x1="0" y1="70" x2="120" y2="70" stroke="#c0b5a4" stroke-width="1"/>
                                <line x1="0" y1="105" x2="120" y2="105" stroke="#c0b5a4" stroke-width="1"/>
                                <line x1="30" y1="0" x2="30" y2="35" stroke="#c0b5a4" stroke-width="1"/>
                                <line x1="75" y1="0" x2="75" y2="35" stroke="#c0b5a4" stroke-width="1"/>
                                <line x1="15" y1="35" x2="15" y2="70" stroke="#c0b5a4" stroke-width="1"/>
                                <line x1="60" y1="35" x2="60" y2="70" stroke="#c0b5a4" stroke-width="1"/>
                                <line x1="100" y1="35" x2="100" y2="70" stroke="#c0b5a4" stroke-width="1"/>
                                <rect x="0" y="118" width="120" height="22" fill="#b8ad9e"/>
                                <!-- Slightly off-balance squat -->
                                <rect x="48" y="95" width="10" height="28" rx="3" fill="#1a1a1a" transform="rotate(-8 48 95)"/>
                                <rect x="64" y="97" width="10" height="26" rx="3" fill="#1a1a1a" transform="rotate(20 74 97)"/>
                                <rect x="38" y="116" width="18" height="7" rx="2" fill="#333"/>
                                <rect x="64" y="117" width="16" height="7" rx="2" fill="#333"/>
                                <rect x="45" y="74" width="12" height="28" rx="4" fill="#1a1a1a" transform="rotate(25 45 74)"/>
                                <rect x="63" y="75" width="12" height="28" rx="4" fill="#1a1a1a" transform="rotate(-20 75 75)"/>
                                <!-- Torso more upright (worse form) -->
                                <rect x="49" y="46" width="20" height="34" rx="5" fill="#1a1a1a" transform="rotate(3 49 46)"/>
                                <line x1="51" y1="60" x2="36" y2="72" stroke="#1a1a1a" stroke-width="7" stroke-linecap="round"/>
                                <line x1="67" y1="58" x2="80" y2="68" stroke="#1a1a1a" stroke-width="7" stroke-linecap="round"/>
                                <circle cx="58" cy="36" r="14" fill="#c8a882"/>
                                <path d="M 44 28 Q 58 18 72 28 Q 70 22 58 20 Q 46 22 44 28Z" fill="#2a1a0a"/>
                            </svg>
                        </div>
                    </div>
                </div>

                <!-- Action Buttons -->
                <div class="ir-action-btns">
                    <button class="ir-action-btn">View Metrics</button>
                    <button class="ir-action-btn">Compare</button>
                    <button class="ir-action-btn">Advanced</button>
                </div>

            </div>

        </div>
    </div>

    <script>
        // Line chart: Average Jump Height over months
        const ctx = document.getElementById('jumpLineChart').getContext('2d');
        new Chart(ctx, {
            type: 'line',
            data: {
                labels: ['Oct', 'Nov', 'Dec', 'Jan', 'Feb', 'Mar', 'Apr', 'May'],
                datasets: [{
                    data: [17.6, 17.8, 17.9, 18.2, 18.4, 18.8, 19.2, 19.9],
                    borderColor: '#1d1d1f',
                    borderWidth: 2,
                    pointBackgroundColor: '#1d1d1f',
                    pointRadius: 3,
                    pointHoverRadius: 5,
                    tension: 0.3,
                    fill: false
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false }
                },
                scales: {
                    x: {
                        grid: { display: false },
                        ticks: { font: { size: 11 }, color: '#999' }
                    },
                    y: {
                        min: 17.0,
                        max: 19.0,
                        ticks: {
                            stepSize: 0.4,
                            font: { size: 11 },
                            color: '#999'
                        },
                        grid: { color: '#f0f0f0' }
                    }
                }
            }
        });

        // Nav click handler
        document.querySelectorAll('.nav-item').forEach(item => {
            item.addEventListener('click', function () {
                document.querySelectorAll('.nav-item').forEach(i => i.classList.remove('active'));
                this.classList.add('active');
            });
        });
    </script>

</body>
</html>